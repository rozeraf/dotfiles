// ~/.config/niri/config.kdl

// ============================================================
// Base
// ============================================================

prefer-no-csd

// [+] XCURSOR_THEME/SIZE нужны для X11-приложений через xwayland-satellite,
//     CURSOR_THEME/SIZE - для части GTK3/Qt приложений которые игнорируют xcursor.
environment {
    QT_QPA_PLATFORMTHEME "qt6ct"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    MOZ_ENABLE_WAYLAND "1"
    MOZ_DBUS_REMOTE "1"
    XCURSOR_THEME "Bibata-Modern-Classic"
    XCURSOR_SIZE "20"
}

debug {
    honor-xdg-activation-with-invalid-serial
}

cursor {
    xcursor-theme "Bibata-Modern-Classic"
    xcursor-size 20
}

// ============================================================
// Input
// ============================================================

input {
    keyboard {
        xkb {
            layout "us,ru"
            options "grp:win_space_toggle"
        }

        track-layout "global"
        repeat-delay 250
        repeat-rate 50
    }

    touchpad {
        tap
        // [+] natural-scroll: направление как на телефоне / macOS.
        //     Убери если привык к обратному.
        natural-scroll
        drag-lock
        // [-] three-finger-drag убран: drag-lock уже включён, они конфликтуют.
        accel-profile "flat"
        accel-speed -0.5
        // [+] scroll-factor: замедляет жест скролла по workspace'ам.
        //     0.3 - плавно, 1.0 - дефолт (слишком быстро на большинстве тачпадов).
        scroll-factor 0.3
    }

    mouse {
        accel-profile "flat"
        accel-speed -0.7
    }

    focus-follows-mouse max-scroll-amount="0%"
}

// ============================================================
// Layout
// ============================================================

layout {
    gaps 15

    center-focused-column "on-overflow"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 0.9
    }

    preset-window-heights {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        off
    }

    border {
        on
        width 2
        active-color "#33ccff"
        inactive-color "#595959"
        urgent-color "#ff9933"
    }

    shadow {
        on
        softness 8
        spread 4
        offset x=0 y=5
        color "#1a1a1aee"
    }
}

// ============================================================
// Animations
// ============================================================

// [+] Весь блок отсутствовал. Spring-анимации - одна из главных фич niri.
//     stiffness: жёсткость пружины (200 = мягко, 1000 = резко).
//     damping-ratio: 1.0 = нет колебаний (критическое затухание).
//     epsilon: порог остановки, влияет на "хвост" анимации.
animations {
    // Движение окна при перемещении колонок.
    window-movement {
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    // Горизонтальный скролл ленты (переключение колонок/фокуса).
    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    // Вертикальное движение между workspace'ами.
    workspace-switch {
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    // Открытие окна.
    window-open {
        duration-ms 200
        curve "ease-out-expo"
    }

    // Закрытие окна.
    window-close {
        duration-ms 150
        curve "ease-out-quad"
    }

    // Ресайз колонки (Super+R, Super+Minus/Equal).
    window-resize {
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    // Overview (Super+O).
    overview-open-close {
        duration-ms 250
        curve "ease-out-expo"
    }
}

// ============================================================
// Noctalia layer rules
// ============================================================

layer-rule {
    match namespace="^noctalia-overview*"
    place-within-backdrop true
}

// ============================================================
// Startup
// ============================================================

spawn-sh-at-startup "dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE DISPLAY && systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE DISPLAY"

spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"

spawn-at-startup "noctalia" "--daemon"

spawn-sh-at-startup "wl-paste --type text --watch cliphist store"
spawn-sh-at-startup "wl-paste --type image --watch cliphist store"

// ============================================================
// Screenshots
// ============================================================

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// ============================================================
// Global window appearance
// ============================================================

window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

// ============================================================
// Binds
// ============================================================

binds {
    // ------------------------------------------------------------
    // Help / launcher / apps
    // ------------------------------------------------------------
    Mod+Shift+C repeat=false { spawn "~/.local/bin/niri-click-target"; }
    Mod+Ctrl+C  repeat=false { spawn "~/.local/bin/niri-lr-click-toggle"; }
    Super+Shift+Slash { show-hotkey-overlay; }

    // скриншоты
    Mod+Shift+S            { spawn-sh "noctalia msg screenshot-region"; }
    Mod+S      { spawn-sh "noctalia msg screenshot-fullscreen"; }
    Mod+Alt+S        { spawn-sh "noctalia msg screenshot-fullscreen all"; }

    Mod+D {
        spawn-sh "noctalia msg panel-toggle launcher";
    }

    // clipboard history
    Mod+V            { spawn-sh "noctalia msg panel-toggle clipboard"; }

    Super+Return hotkey-overlay-title="Terminal" { spawn "kitty"; }
    Super+E hotkey-overlay-title="File manager" { spawn "thunar"; }
    Super+W hotkey-overlay-title="Browser" { spawn "zen-browser"; }
    // [fix] Было hotkey-overlay-title="Browser" - неверное название.
    Super+Q hotkey-overlay-title="Close window" { close-window; }

    Super+D repeat=false hotkey-overlay-title="Noctalia launcher" {
        spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "toggle";
    }

    Super+V repeat=false hotkey-overlay-title="Clipboard" {
        spawn-sh "qs -c noctalia-shell ipc call plugin:clipper toggle";
    }

    // ------------------------------------------------------------
    // Screenshots / annotate
    // ------------------------------------------------------------

    Super+Shift+S repeat=false hotkey-overlay-title="Annotate screenshot" {
        spawn-sh "qs -c noctalia-shell ipc call plugin:screen-toolkit annotate";
    }

    Super+Shift+O repeat=false hotkey-overlay-title="google lens" {
        spawn-sh "qs -c noctalia-shell ipc call plugin:screen-toolkit lens";
    }

    Print repeat=false hotkey-overlay-title="Screenshot region" {
        spawn-sh "qs -c noctalia-shell ipc call plugin:screen-toolkit screenshotRegion";
    }

    Shift+Print repeat=false hotkey-overlay-title="Screenshot monitor" {
        spawn-sh "qs -c noctalia-shell ipc call plugin:screen-toolkit screenshotMonitor";
    }

    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }

    // ------------------------------------------------------------
    // Session
    // ------------------------------------------------------------

    Super+Escape repeat=false hotkey-overlay-title="Lock screen" {
        spawn-sh "qs -c noctalia-shell ipc call lockScreen toggle";
    }

    Super+Shift+Escape { quit; }

    Ctrl+Alt+Delete { quit; }

    Super+Ctrl+Escape allow-inhibiting=false {
        toggle-keyboard-shortcuts-inhibit;
    }

    // ------------------------------------------------------------
    // Overview
    // ------------------------------------------------------------

    Super+Tab repeat=false hotkey-overlay-title="Noctalia workspace overview" {
        spawn-sh "qs -c noctalia-shell ipc call plugin:workspace-overview toggle";
    }

    Super+O repeat=false hotkey-overlay-title="Niri overview" {
        toggle-overview;
    }

    // ------------------------------------------------------------
    // Focus: arrows + HJKL
    // ------------------------------------------------------------

    Super+Left { focus-column-left; }
    Super+Right { focus-column-right; }
    Super+Up { focus-window-up; }
    Super+Down { focus-window-down; }

    Super+H { focus-column-left; }
    Super+J { focus-window-down; }
    Super+K { focus-window-up; }
    Super+L { focus-column-right; }

    Super+Home { focus-column-first; }
    Super+End { focus-column-last; }

    // ------------------------------------------------------------
    // Move windows / columns
    // ------------------------------------------------------------

    Super+Shift+Left { move-column-left; }
    Super+Shift+Right { move-column-right; }
    Super+Shift+Up { move-window-up; }
    Super+Shift+Down { move-window-down; }

    Super+Shift+H { move-column-left; }
    Super+Shift+J { move-window-down; }
    Super+Shift+K { move-window-up; }
    Super+Shift+L { move-column-right; }

    Super+Ctrl+Left { move-column-left; }
    Super+Ctrl+Right { move-column-right; }
    Super+Ctrl+Up { move-window-up; }
    Super+Ctrl+Down { move-window-down; }

    Super+Ctrl+H { move-column-left; }
    Super+Ctrl+J { move-window-down; }
    Super+Ctrl+K { move-window-up; }
    Super+Ctrl+L { move-column-right; }

    Super+Ctrl+Home { move-column-to-first; }
    Super+Ctrl+End { move-column-to-last; }

    // ------------------------------------------------------------
    // Monitors
    // ------------------------------------------------------------

    Super+Alt+H { focus-monitor-left; }
    Super+Alt+J { focus-monitor-down; }
    Super+Alt+K { focus-monitor-up; }
    Super+Alt+L { focus-monitor-right; }

    Super+Ctrl+Alt+H { move-column-to-monitor-left; }
    Super+Ctrl+Alt+J { move-column-to-monitor-down; }
    Super+Ctrl+Alt+K { move-column-to-monitor-up; }
    Super+Ctrl+Alt+L { move-column-to-monitor-right; }

    // ------------------------------------------------------------
    // Column workflow
    // ------------------------------------------------------------

    Super+R { switch-preset-column-width; }
    Super+Shift+R { switch-preset-column-width-back; }

    Super+Minus { set-column-width "-10%"; }
    Super+Equal { set-column-width "+10%"; }

    Super+Shift+Minus { set-window-height "-10%"; }
    Super+Shift+Equal { set-window-height "+10%"; }

    Super+F { maximize-column; }
    Super+Shift+F { fullscreen-window; }

    Super+M { maximize-window-to-edges; }

    Super+Ctrl+F { expand-column-to-available-width; }

    Super+C { center-column; }
    Super+Ctrl+C { center-visible-columns; }

    Super+P { toggle-window-floating; }
    Super+Ctrl+P { switch-focus-between-floating-and-tiling; }

    Super+G { toggle-column-tabbed-display; }

    Super+Z { switch-preset-window-height; }
    Super+Ctrl+Z { reset-window-height; }

    Super+BracketLeft { consume-or-expel-window-left; }
    Super+BracketRight { consume-or-expel-window-right; }
    Super+Comma { consume-window-into-column; }
    Super+Period { expel-window-from-column; }

    // ------------------------------------------------------------
    // Workspaces
    // ------------------------------------------------------------

    Super+1 { focus-workspace 1; }
    Super+2 { focus-workspace 2; }
    Super+3 { focus-workspace 3; }
    Super+4 { focus-workspace 4; }
    Super+5 { focus-workspace 5; }
    Super+6 { focus-workspace 6; }
    Super+7 { focus-workspace 7; }
    Super+8 { focus-workspace 8; }
    Super+9 { focus-workspace 9; }
    Super+0 { focus-workspace 10; }

    Super+Alt+1 { move-window-to-workspace 1; }
    Super+Alt+2 { move-window-to-workspace 2; }
    Super+Alt+3 { move-window-to-workspace 3; }
    Super+Alt+4 { move-window-to-workspace 4; }
    Super+Alt+5 { move-window-to-workspace 5; }
    Super+Alt+6 { move-window-to-workspace 6; }
    Super+Alt+7 { move-window-to-workspace 7; }
    Super+Alt+8 { move-window-to-workspace 8; }
    Super+Alt+9 { move-window-to-workspace 9; }
    Super+Alt+0 { move-window-to-workspace 10; }

    Super+Page_Down { focus-workspace-down; }
    Super+Page_Up { focus-workspace-up; }

    Super+Ctrl+Page_Down { move-window-to-workspace-down; }
    Super+Ctrl+Page_Up { move-window-to-workspace-up; }

    Super+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Super+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }

    Super+WheelScrollRight { focus-column-right; }
    Super+WheelScrollLeft { focus-column-left; }

    Super+Shift+WheelScrollDown { focus-column-right; }
    Super+Shift+WheelScrollUp { focus-column-left; }

    Super+Ctrl+WheelScrollRight { move-column-right; }
    Super+Ctrl+WheelScrollLeft { move-column-left; }

    Super+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Super+Ctrl+Shift+WheelScrollUp { move-column-left; }

    // ------------------------------------------------------------
    // Audio / media
    // ------------------------------------------------------------

    XF86AudioRaiseVolume allow-when-locked=true {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05+ -l 1.0";
    }

    XF86AudioLowerVolume allow-when-locked=true {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.05-";
    }

    XF86AudioMute allow-when-locked=true {
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle";
    }

    XF86AudioMicMute allow-when-locked=true {
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle";
    }

    XF86AudioPlay allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev allow-when-locked=true { spawn "playerctl" "previous"; }
    XF86AudioNext allow-when-locked=true { spawn "playerctl" "next"; }

    Super+Shift+N { spawn "playerctl" "next"; }
    Super+Shift+B { spawn "playerctl" "previous"; }
    Super+Shift+P { spawn "playerctl" "play-pause"; }

    // ------------------------------------------------------------
    // Brightness
    // ------------------------------------------------------------

    XF86MonBrightnessUp allow-when-locked=true {
        spawn "brightnessctl" "--class=backlight" "set" "+10%";
    }

    XF86MonBrightnessDown allow-when-locked=true {
        spawn "brightnessctl" "--class=backlight" "set" "10%-";
    }
}

// ============================================================
// Window rules
// ============================================================

window-rule {
    match app-id="pavucontrol"
    open-floating true
}

window-rule {
    match app-id="nm-connection-editor"
    open-floating true
}

window-rule {
    match app-id="blueman-manager"
    open-floating true
}

window-rule {
    match title="File Operation Progress"
    open-floating true
}

window-rule {
    match app-id="xdg-desktop-portal-gtk"
    open-floating true
}

window-rule {
    match title="^Picture-in-Picture$"
    open-floating true
}

// [+] Диалоги открытия/сохранения файлов - всегда floating.

window-rule {
    match app-id="kitty"
    default-column-width { proportion 0.5; }
}

window-rule {
    match app-id="zen-browser"
    default-column-width { proportion 0.66667; }
}

// [+] Добавь своё IDE сюда. app-id можно узнать через:
//     niri msg windows | grep app-id
// Примеры:
//
// window-rule {
//     match app-id="dev.zed.Zed"
//     default-column-width { proportion 0.9; }
// }
//
// window-rule {
//     match app-id="com.vscodium.codium"
//     default-column-width { proportion 0.9; }
// }
//
// window-rule {
//     match app-id="jetbrains-.*"
//     default-column-width { proportion 0.9; }
// }

include "./noctalia.kdl"
